<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:gravity="center" android:padding="32dp" android:background="@color/background">
        <TextView android:id="@+id/tvAppTitle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🔍 Life Hacks Quiz" android:textSize="28sp" android:textStyle="bold" android:textColor="@color/text_primary" android:layout_marginBottom="24dp"/>
        <TextView android:id="@+id/tvWelcomeMessage" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="16sp" android:textColor="@color/text_secondary" android:gravity="center" android:lineSpacingMultiplier="1.4" android:layout_marginBottom="48dp"/>
        <Button android:id="@+id/btnStart" android:layout_width="200dp" android:layout_height="wrap_content" android:text="Start Quiz" android:textSize="18sp" android:padding="16dp" android:backgroundTint="@color/primary"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>